    <LinearLayout
        android:layout_margin="10dp"
        android:weightSum="3"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="100dp">

        <LinearLayout
            android:gravity="center|start"
            android:layout_weight="0.7"
            android:layout_width="0dp"
            android:layout_height="match_parent">

            <ImageView
                android:background="@drawable/logo"
                android:layout_width="80dp"
                android:layout_height="80dp"/>


        </LinearLayout>

        <LinearLayout
            android:gravity="start|center"
            android:orientation="vertical"
            android:layout_weight="2"
            android:layout_width="0dp"
            android:layout_height="match_parent">

            <TextView
                android:textStyle="bold"
                android:textSize="16sp"
                android:id="@+id/userName"
                android:textColor="@color/primary_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:textStyle="normal"
                android:textSize="14sp"
                android:id="@+id/mobileNumber"
                android:textColor="@color/primary_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
            android:gravity="center"
            android:layout_weight="0.3"
            android:layout_width="0dp"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/option"
                android:background="@drawable/more"
                android:layout_width="20dp"
                android:layout_height="20dp"/>

            <ImageView
                android:id="@+id/logOut"
                android:visibility="gone"
                android:background="@drawable/logout"
                android:layout_width="20dp"
                android:layout_height="20dp"/>

        </LinearLayout>


    </LinearLayout>


    <!-- Compact Date Selection Row -->
    <LinearLayout

        android:gravity="center"
        android:layout_margin="10dp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"

        android:weightSum="3"
        android:elevation="2dp">

        <!-- In your activity_main_dashboard.xml -->
        <TextView
            android:id="@+id/tvSelectedDateFrom"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.1"
            android:text="Start Date"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/date_selector_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tvSelectedDateTo"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.1"
            android:text="End Date"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/date_selector_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Fetch Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFetchData"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="0.8"
            android:text="Show"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/button_primary"
            android:textAllCaps="false"
            />

    </LinearLayout>

    <!-- Content Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Select date range and click Fetch Report"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#7f8c8d"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </RelativeLayout>

</LinearLayout>