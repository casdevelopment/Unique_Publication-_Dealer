<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/mainLayout"
    android:background="@color/background_light">
    <RelativeLayout

        android:background="@color/primary_color"
        android:layout_width="match_parent"
        android:layout_height="?actionBarSize">

        <TextView
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:text="@string/app_name"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <ImageView
            android:id="@+id/logOut"
            android:backgroundTint="@color/white"
            android:layout_marginEnd="20dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/logout"
            android:layout_width="20dp"
            android:layout_height="20dp"/>



    </RelativeLayout>

    <!-- Compact Date Selection Row -->
    <LinearLayout

        android:gravity="center"
        android:layout_margin="10dp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"

        android:weightSum="3"
        android:elevation="2dp">

        <!-- In your activity_main_dashboard.xml -->
        <TextView
            android:id="@+id/tvSelectedDateFrom"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.1"
            android:text="Start Date"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/date_selector_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tvSelectedDateTo"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.1"
            android:text="End Date"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/date_selector_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Fetch Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFetchData"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="0.8"
            android:text="Show"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/button_primary"
            android:textAllCaps="false"
            />

    </LinearLayout>



    <!-- Content Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Select date range and click Fetch Report"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#7f8c8d"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </RelativeLayout>

</LinearLayout>