<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    >

    <FrameLayout
        android:id="@+id/profileBanner"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="5dp">

        <!-- Full width banner image -->
        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_user_placeholder" />

        <!-- Semi-transparent overlay for text contrast -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#33000000" /> <!-- 20% black -->

        <!-- Menu icon top-right -->
        <ImageView
            android:id="@+id/option"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:padding="6dp"
            android:src="@drawable/more"
            app:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:elevation="4dp"
            android:outlineProvider="background" />

    </FrameLayout>

    <!-- ================= USER DETAILS CARD ================= -->
    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_below="@id/profileBanner"
        android:layout_marginTop="-30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card_bg"
        android:elevation="6dp"
        android:padding="16dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp">

        <!-- User Name -->
        <TextView
            android:id="@+id/userName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:gravity="center"/>

        <!-- Account Name -->
        <TextView
            android:id="@+id/accountName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Account: Premium"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

        <!-- Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/locationsvg"
                app:tint="@color/primary_color"/>

            <TextView
                android:id="@+id/address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New York, USA"
                android:textColor="#666666"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- Mobile Number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/phonesvg"
                app:tint="@color/primary_color"/>

            <TextView
                android:id="@+id/mobileNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+1 234 567 890"
                android:textColor="#666666"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- Party Group -->
<!--        <TextView-->
<!--            android:id="@+id/partyGroup"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:text="Premium Users Group"-->
<!--            android:textSize="14sp"-->
<!--            android:textColor="@color/primary_color"-->
<!--            android:gravity="center"-->
<!--            android:layout_marginTop="8dp"/>-->
    </LinearLayout>

