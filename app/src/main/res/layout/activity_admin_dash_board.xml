<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_margin="4dp"
    android:fitsSystemWindows="true"
    android:background="@color/background_light"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_alignParentTop="true"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:weightSum="3"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:gravity="center|start"
            android:layout_weight="0.7"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <ImageView
                android:background="@drawable/logo"
                android:layout_width="80dp"
                android:layout_height="80dp"/>


        </LinearLayout>

        <LinearLayout
            android:gravity="start|center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:layout_weight="2"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:fontFamily="@font/jost_bold"
                android:textStyle="bold"
                android:textSize="16sp"
                android:id="@+id/userName"
                android:textColor="@color/primary_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:fontFamily="@font/jost_regular"
                android:textSize="14sp"
                android:id="@+id/accountName"
                android:textColor="@color/primary_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                />
            <TextView
                android:fontFamily="@font/jost_regular"
                android:textSize="14sp"
                android:id="@+id/address"
                android:textColor="@color/primary_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>



            <TextView
                android:fontFamily="@font/jost_regular"
                android:textStyle="normal"
                android:textSize="14sp"
                android:id="@+id/mobileNumber"
                android:textColor="@color/primary_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView
                android:fontFamily="@font/jost_regular"
                android:textSize="14sp"
                android:id="@+id/partyGroup"
                android:textColor="@color/primary_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

        </LinearLayout>

        <LinearLayout
            android:gravity="center"
            android:layout_weight="0.3"
            android:layout_width="0dp"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/option"
                android:background="@drawable/more"
                android:layout_width="20dp"
                android:layout_height="20dp"/>

            <ImageView
                android:id="@+id/logOut"
                android:visibility="gone"
                android:background="@drawable/logout"
                android:layout_width="20dp"
                android:layout_height="20dp"/>


        </LinearLayout>


    </LinearLayout>

    <View
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:id="@+id/viewLine"
        android:layout_below="@id/topLayout"
        android:background="@color/primary_color"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginTop="20dp"
        android:layout_below="@id/topLayout"
        >


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            >

            <LinearLayout
                android:id="@+id/btnAddUsers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary_light"
                android:background="@drawable/rounded_card_bg"
                android:gravity="center"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/add_user"
                    android:contentDescription="icon"
                    app:tint="@color/white"/>

                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Add User"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/white" />

                <!--                <TextView-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:text="Total Amount"-->
                <!--                    android:textStyle="bold"-->
                <!--                    android:fontFamily="@font/poppins"-->
                <!--                    android:textSize="13sp"-->
                <!--                    android:textColor="@color/blackLight"-->
                <!--                    android:gravity="center"/>-->

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnInactivateUser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary_light"
                android:background="@drawable/rounded_card_bg"
                android:gravity="center">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/inactive_user"
                    android:contentDescription="icon"
                    app:tint="@color/white"/>

                <TextView
                    android:id="@+id/tvTotalSales"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Inactive User"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/white" />

                <!--                <TextView-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:text="Total Eggs Sold"-->
                <!--                    android:textStyle="bold"-->
                <!--                    android:fontFamily="@font/poppins"-->
                <!--                    android:textSize="13sp"-->
                <!--                    android:textColor="@color/blackLight"-->
                <!--                    android:gravity="center"/>-->

            </LinearLayout>


        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/btnResetPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary_light"
                android:background="@drawable/rounded_card_bg"
                android:gravity="center"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/password"
                    android:contentDescription="icon"
                    app:tint="@color/white"/>

                <TextView
                    android:id="@+id/tvRecieved"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Reset Password"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/white" />

                <!--                <TextView-->
